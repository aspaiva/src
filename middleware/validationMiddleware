const Joi = require('joi');
const jwt = require('jsonwebtoken');

function validateMovie (req, res, next) {
    const schema = Joi.object({
        titulo: Joi.string().min(2).required(),
        duracao: Joi.number().integer().min(1).required(),
        sinopse: Joi.string().min(25).required(),
        dataLancamento: Joi.date().required(),
        imagem: Joi.string().uri().required()
    });

    const { error } = schema.validate(req.body);
    if (error) {
        return res.status(400).json({ error: error.details[0].message });
    }
    next();
}

function validateCinema (req, res, next) {
    const schema = Joi.object({
        nome: Joi.string().min(2).required(),
        cidadeId: Joi.string().min(4).required()
    });

    const { error } = schema.validate(req.body);
    if (error) {
        return res.status(400).json({ error: error.details[0].message });
    }
    next();
}

// Middleware to validate token antes das ações que precisam de autenticação (logout, etc)
function validateToken(req, res, next) {
    try {
        let token = req.headers['authorization'];
        token = token.replace('Bearer ', ''); // Remove 'Bearer ' prefix if present

        if (!token) {
            return res.status(401).json({ message: 'No token provided' });
        }

        const decoded = jwt.verify(token, process.env.JWT_SECRET);
        res.locals.user = decoded; // Store decoded info in res.locals
        console.log(`Authenticated user: ${decoded.username}`);

        next();

    } catch (err) {
        console.error(err);
        res.status(401).json({ message: 'Token inválido ou não informado' });
    }
}

function validateAdmin(req, res, next) {
    const user = res.locals.user;
    if (user.role.toLowerCase() !== 'admin') {
        return res.status(403).json({ message: 'Access denied: Admins only' });
    }
    next();
}

module.exports = {
    validateMovie, validateCinema, validateToken, validateAdmin
};